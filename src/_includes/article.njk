{% extends "base.njk" %}

{% block content %}
<main class="max-w-[680px] mx-auto px-5">

<nav class="pt-5 font-sans text-[.8rem]">
  <a href="../" class="text-link hover:underline">&larr; Back</a>
</nav>

<hr class="border-0 border-t border-rule my-7">

<article>
  <h1 class="text-2xl md:text-3xl font-bold mb-2 leading-tight">{{ title }}</h1>
  <p class="font-sans text-[1.2rem] text-muted mb-6">{{ subtitle }}</p>

  <div class="text-[1.05rem] leading-relaxed [&>:first-child]:mt-0 [&_a]:text-link">
    {{ content | safe }}
  </div>
</article>

</main>
{% endblock %}
